1.Counter with Increase and Decrease (Using Prev)import { useState } from "react";

function Counter() {
  const [count, setCount] = useState(0);

  const increase = () => {
    setCount(prev => prev + 1);
  };

  const decrease = () => {
    setCount(prev => prev - 1);
  };

  return (
    <div>
      <h2>Count: {count}</h2>
      <button onClick={increase}>Increase</button>
      <button onClick={decrease}>Decrease</button>
    </div>
  );
}

export default Counter;




2.Counter with Increase Twice Button

import { useState } from "react";

function CounterTwice() {
  const [count, setCount] = useState(0);

  const increaseTwice = () => {
    setCount(prev => prev + 1);
    setCount(prev => prev + 1);
  };

  return (
    <div>
      <h2>Count: {count}</h2>
      <button onClick={increaseTwice}>Increase Twice</button>
    </div>
  );
}

export default CounterTwice;


3.Toggle Show / Hide Text (Using Prev)

import { useState } from "react";

function ToggleText() {
  const [show, setShow] = useState(true);

  const toggleText = () => {
    setShow(prev => !prev);
  };

  return (
    <div>
      <button onClick={toggleText}>Toggle</button>

      {show && <p>This text can be hidden</p>}
    </div>
  );
}

export default ToggleText;


4.Update Object State (Change Only Age)


import { useState } from "react";

function UserProfile() {
  const [user, setUser] = useState({
    name: "Lena",
    age: 20
  });

  const increaseAge = () => {
    setUser(prev => ({
      ...prev,
      age: prev.age + 1
    }));
  };

  return (
    <div>
      <h2>Name: {user.name}</h2>
      <h2>Age: {user.age}</h2>

      <button onClick={increaseAge}>Increase Age</button>
    </div>
  );
}

export default UserProfile;
